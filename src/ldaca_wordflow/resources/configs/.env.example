# Environment Configuration for LDaCA Web App Backend

# User data folder (relative or absolute path)
DATA_ROOT=data

# Database Configuration (DATABASE_URL optional; if omitted, DB path = DATA_ROOT/DATABASE_FILE)
# DATABASE_URL=sqlite+aiosqlite:///.data/users.db
DATABASE_FILE=users.db
DATABASE_BACKUP_FOLDER=backups

# Data Folders (relative to DATA_ROOT)
USER_DATA_FOLDER=users

# Server Configuration
BACKEND_PORT=8001
DEBUG=false

# Authentication Configuration
# Multi-user mode: true = require Google OAuth, false = single root user
MULTI_USER=false

# Single user configuration (when MULTI_USER=false)
SINGLE_USER_ID=root
SINGLE_USER_NAME=Root User
SINGLE_USER_EMAIL=root@localhost

# Google OAuth Configuration (when MULTI_USER=true)
GOOGLE_CLIENT_ID=your-google-client-id-here

# CILogon OIDC Configuration (when MULTI_USER=true)
# Obtain client credentials from your CILogon administrator.
# CILOGON_CLIENT_ID and CILOGON_CLIENT_SECRET are issued when the client is registered.
# CILOGON_REDIRECT_URI must match the callback URL registered with CILogon exactly.
CILOGON_CLIENT_ID=cilogon:/client_id/your-client-id-here
CILOGON_CLIENT_SECRET=your-cilogon-client-secret-here
# Discovery URL — change to the production endpoint when ready:
#   Production: https://cilogon.aaf.edu.au/.well-known/openid-configuration
#   Test:       https://test.cilogon.aaf.edu.au/.well-known/openid-configuration
CILOGON_DISCOVERY_URL=https://test.cilogon.aaf.edu.au/.well-known/openid-configuration
# Full callback URL that you gave to your CILogon administrator, e.g.:
#   https://your-nectar-host.example.com/api/auth/cilogon/callback
CILOGON_REDIRECT_URI=https://your-host.example.com/api/auth/cilogon/callback

# Security Configuration
TOKEN_EXPIRE_HOURS=24
SECRET_KEY=your-secret-key-here

# Oni API key
ONI_API_KEY=your-oni-api-key-here
