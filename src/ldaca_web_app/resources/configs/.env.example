# Environment Configuration for LDaCA Web App Backend

# User data folder (relative or absolute path)
DATA_ROOT=data

# Database Configuration (DATABASE_URL optional; if omitted, DB path = DATA_ROOT/DATABASE_FILE)
# DATABASE_URL=sqlite+aiosqlite:///.data/users.db
DATABASE_FILE=users.db
DATABASE_BACKUP_FOLDER=backups

# Data Folders (relative to DATA_ROOT)
USER_DATA_FOLDER=users

# Server Configuration
BACKEND_PORT=8001
DEBUG=false

# Authentication Configuration
# Multi-user mode: true = require Google OAuth, false = single root user
MULTI_USER=false

# Single user configuration (when MULTI_USER=false)
SINGLE_USER_ID=root
SINGLE_USER_NAME=Root User
SINGLE_USER_EMAIL=root@localhost

# Google OAuth Configuration (when MULTI_USER=true)
GOOGLE_CLIENT_ID=your-google-client-id-here

# Security Configuration
TOKEN_EXPIRE_HOURS=24
SECRET_KEY=your-secret-key-here

# Oni API key
ONI_API_KEY=your-oni-api-key-here
